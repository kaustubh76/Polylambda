# PolyLambda env — copy to .env and fill in. NEVER commit .env.

# --- data layer ---
# Historical backbone: the public HF dataset (moose-code/polymarket-onchain-v1) via DuckDB.
DATA_SOURCE=hf                                 # hf | graphql  (which backend fetch_fills/recon use)
HF_DATASET=moose-code/polymarket-onchain-v1    # the on-chain parquet dataset (queried in place)
HF_TOKEN=                                      # HF read token. HF_ACCESS_TOKEN also works (same thing).
                                               # Raises rate limits AND unlocks the Hub-only tables the
                                               # HF panels use (orderbook volume, full order_filled tape).
                                               # Loaded from .env by data/hf.py for the app AND the CLI
                                               # jobs (precompute / export_disputes / calibrate).
DATA_CACHE_DIR=.data_cache                     # local parquet cache for the replay slice (gitignored)
# Local Envio indexer — now scoped to ONLY the OOv2 dispute lifecycle (HF has no OOv2 disputes).
GRAPHQL_URL=http://localhost:8080/v1/graphql   # Envio/Hasura endpoint (disputes/proposals)
DATABASE_URL=postgres://postgres:testing@localhost:5432/envio-dev
# Hosted Envio HyperIndex the dashboard's live dispute stream reads (webapp/backend/live.py).
# Also gates the live paths: /api/recon/live and /api/ablation?live=1 attempt the real engine when set.
INDEXER_GRAPHQL_URL=https://indexer.dev.hyperindex.xyz/0638687/v1/graphql
# RPC for on-chain verification / recon reorg-tail spot-checks. recon_live accepts any of
# POLYGON_RPC / RPC_URL / AMOY_RPC_URL / POLYGON_RPC_URL (the deploy configs set AMOY_RPC_URL).
POLYGON_RPC_URL=
AMOY_RPC_URL=https://polygon-amoy.drpc.org     # testnet chain reads/writes (webapp/backend/chain.py) + recon RPC

# --- run mode ---
MODE=paper                                     # paper | paper-live | live
MAX_CAPITAL_USDC=50                            # hard cap; keep tiny until edge is validated
POSITIONING=both                               # reward_farmer | jump_avoid | both

# --- on-chain testnet market (Polygon Amoy, chainId 80002; webapp/backend/chain.py + scripts/) ---
# Deployed demo instance (also baked into fly.toml / render.yaml / webapp/backend/market.json):
MARKET_ADDRESS=0x1dBF7dA731e58C87B7e6644b719b84804F28b496
AMOY_USDC_ADDRESS=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582   # Circle test USDC on Amoy
AMOY_GAS_GWEI=30                               # explicit priority fee (Amoy base fee ~0)
ENGINE_COLLATERAL_USDC=1                       # deploy-time collateral funded by deploy_market.py
ENGINE_MAX_TRADE=0.5                           # per-trade YES-share cap posted with each quote
# Engine signer for postQuote/flagDispute/resolve — written into the gitignored .env by
# `python scripts/gen_engine_wallet.py`. NEVER commit these; in deploys they are secrets
# (`fly secrets set` / Render dashboard, sync:false).
# ENGINE_PRIVATE_KEY=
# ENGINE_ADDRESS=

# --- execution (only for live / paper-live; CLOB V2) ---
# ⚠ live trading is JURISDICTION-GATED — see JURISDICTION.md before setting these.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
WALLET_PRIVATE_KEY=                            # L1 EIP-712 signer (derives API creds)
BUILDER_CODE=                                  # bytes32 Builder Code for reward attribution
